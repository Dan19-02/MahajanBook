# Base URL of the Ledgix Backend (used for MiniMax-M3 AI features).
# Copy this file to .env.local and adjust if your backend runs elsewhere.
VITE_API_URL=http://localhost:3001

# Butterbase app id (e.g. app_xxxx). When set, the login screen shows
# "Continue with Google" (Google OAuth is handled by butterbase). Must match the
# backend's BUTTERBASE_APP_ID. Leave blank to hide Google sign-in.
VITE_BUTTERBASE_APP_ID=
VITE_BUTTERBASE_API_BASE=https://api.butterbase.ai
